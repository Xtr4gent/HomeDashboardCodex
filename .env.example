DATABASE_URL="postgresql://postgres:postgres@localhost:5432/home_dashboard?schema=public"
DATABASE_SCHEMA="public"
SESSION_COOKIE_NAME="home_dashboard_session"
SESSION_DAYS="30"
BCRYPT_ROUNDS="12"

# Required in production seed runs. Local seed uses documented development defaults if omitted.
SEED_USER_1_NAME="Gabe"
SEED_USER_1_USERNAME="Gabe"
SEED_USER_1_EMAIL="gabe@example.com"
SEED_USER_1_PASSWORD="change-me-gabe"
SEED_USER_2_NAME="Alessandra"
SEED_USER_2_USERNAME="Alessandra"
SEED_USER_2_EMAIL="alessandra@example.com"
SEED_USER_2_PASSWORD="change-me-alessandra"

# Optional aliases also supported by the seed script.
HOUSEHOLD_ACCOUNT_1_USERNAME="Gabe"
HOUSEHOLD_ACCOUNT_1_EMAIL="gabe@example.com"
HOUSEHOLD_ACCOUNT_1_PASSWORD="change-me-gabe"
HOUSEHOLD_ACCOUNT_2_USERNAME="Alessandra"
HOUSEHOLD_ACCOUNT_2_EMAIL="alessandra@example.com"
HOUSEHOLD_ACCOUNT_2_PASSWORD="change-me-alessandra"
